d adds admin/moderation infrastructure:   CRITICAL FIXES   1. Auto-resolve defaults to POSTER (V3 bug: defaulted to worker, cost $1K+)   2. On-chain claim limits (V3 had API-only — trivially bypassed by direct contract calls)   3. On-chain ban checks via AgentRegistryV2 (V3 had API-only bans)   4. Empty proof rejection (V3 allowed empty submitWork)   5. Minimum deadline duration (V3 allowed 1-second deadlines)   ADMIN CONTROLS   6. adminCancelTask — force-cancel any task, any state   7. adminResolveDispute — instant dispute resolution (no 24h delay)   8. adminPauseTask / adminUnpauseTask — freeze individual tasks   9. emergencyWithdraw — pull funds when contract is paused   10. adminAdjustTimers — tune time constants without redeployment   11. adminSetClaimLimits — tune claim caps   12. adminRevertBannedWorker — revert all tasks from a banned wallet   13. Batch operations — batchAdminCancel, batchAdminResolve   FEE MODEL   14. On-chain fee discount whitelist (replaces self-declared boolean)   15. Tier-based fee rates via AgentRegistryV2 (future: Silver=3%, Gold=2%, Platinum=1%)   QUALITY-OF-LIFE   16. Lifecycle timestamps (posted, claimed, completed, cancelled)   17. nonReentrant on all state-changing functions   18. Per-task pause in addition to global pause   19. Priority claiming window for Silver+ tiers Retained from V3: auto-approve, poster stake, revision requests, mutual cancel, deadline extension, self-claim prevention, keeper-friendly reclaim.","errors":{"EnforcedPause()":[{"details":"The operation failed because the contract is paused."}],"ExpectedPause()":[{"details":"The operation failed because the contract is not paused."}],"OwnableInvalidOwner(address)":[{"details":"The owner is not a valid owner account. (eg. `address(0)`)"}],"OwnableUnauthorizedAccount(address)":[{"details":"The caller account is not authorized to perform an operation."}],"ReentrancyGuardReentrantCall()":[{"details":"Unauthorized reentrant call."}]},"events":{"Paused(address)":{"details":"Emitted when the pause is triggered by `account`."},"Unpaused(address)":{"details":"Emitted when the pause is lifted by `account`."}},"kind":"dev","methods":{"owner()":{"details":"Returns the address of the current owner."},"paused()":{"details":"Returns true if the contract is paused, and false otherwise."},"renounceOwnership()":{"details":"Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner."},"transferOwnership(address)":{"details":"Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner."}},"title":"TaskPoolV4","version":1},"userdoc":{"kind":"user","methods":{"abandonTask(uint256)":{"notice":"Worker abandons a claimed task. 50% stake slashed, task reopens."},"adminAdjustTimers(uint256,uint256,uint256,uint256)":{"notice":"Adjust timer constants without redeployment."},"adminCancelTask(uint256,string)":{"notice":"Force-cancel ANY task in ANY non-terminal state."},"adminPauseTask(uint256)":{"notice":"Pause a specific task."},"adminResolveDispute(uint256,address)":{"notice":"Instant dispute resolution — no 24h delay."},"adminRevertBannedWorker(address,uint256[])":{"notice":"Revert all active tasks from a banned wallet back to Open."},"adminSetClaimLimits(uint256,uint256)":{"notice":"Set on-chain claim limits."},"adminUnpauseTask(uint256)":{"notice":"Unpause a specific task."},"approveWork(uint256)":{"notice":"Poster approves work — USDC to worker, both stakes returned."},"autoResolveDispute(uint256)":{"notice":"Auto-resolve dispute after window expires.         V4 FIX: defaults to POSTER (V3 defaulted to worker — cost $1K+).         Worker must prove delivery, not poster prove non-delivery."},"batchAdminCancel(uint256[],string)":{"notice":"Batch cancel multiple tasks."},"batchAdminResolve(uint256[],address[])":{"notice":"Batch resolve multiple disputes."},"cancelTask(uint256)":{"notice":"Cancel an unclaimed task — poster gets USDC + poster stake back."},"claimApproval(uint256)":{"notice":"Claim auto-approval after poster ghosts. Anyone can call (keeper)."},"claimTask(uint256)":{"notice":"Claim an open task. Worker stakes $AXOBOTL as collateral."},"emergencyWithdraw(address,uint256)":{"notice":"Pull funds in emergency. Contract must be paused first."},"getFeeBps(address)":{"notice":"Get the effective fee rate for a poster."},"postTask(string,uint256,uint256)":{"notice":"Post a new task. Deposits USDC bounty + poster $AXOBOTL stake."},"reclaimExpired(uint256)":{"notice":"Reclaim bounty from an expired claimed task (worker ghosted).         Anyone can trigger (keeper-friendly). Worker stake slashed."},"rejectWork(uint256)":{"notice":"Poster rejects work — starts dispute."},"requestRevision(uint256)":{"notice":"Poster requests revision — task goes back to Claimed."},"resolveDispute(uint256,bool)":{"notice":"Owner resolves dispute after DISPUTE_DELAY timelock."},"submitWork(uint256,string)":{"notice":"Submit proof of work completion."}},"notice":"Bidirectional human↔agent task marketplace with USDC escrow,         dual-sided $AXOBOTL staking, admin controls, on-chain claim limits,         and cross-contract integration with AgentRegistryV2.","version":1}},"settings":{"compilationTarget":{"contracts/TaskPoolV4.sol":"TaskPoolV4"},"evmVersion":"paris","libraries":{},"metadata":{"bytecodeHash":"ipfs"},"optimizer":{"enabled":true,"runs":200},"remappings":[],"viaIR":true},"sources":{"@openzeppelin/contracts/access/Ownable.sol":{"keccak256":"0xff6d0bb2e285473e5311d9d3caacb525ae3538a80758c10649a4d61029b017bb","license":"MIT","urls":["bzz-raw://8ed324d3920bb545059d66ab97d43e43ee85fd3bd52e03e401f020afb0b120f6","dweb:/ipfs/QmfEckWLmZkDDcoWrkEvMWhms66xwTLff9DDhegYpvHo1a"]},"@openzeppelin/contracts/utils/Context.sol":{"keccak256":"0x493033a8d1b176a037b2cc6a04dad01a5c15772